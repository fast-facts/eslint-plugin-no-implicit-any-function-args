{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "dist",
    "lib": [
      "ES2018",
      "dom"
    ],
    "types": [
      "node"
    ],
    "module": "nodenext",
    "target": "ES2018",
    "declaration": true,
    "declarationMap": true,
    "importHelpers": true,
    "inlineSources": true,
    "noEmitHelpers": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitAny": false,
    "noImplicitReturns": true,
    "noImplicitThis": true,
    "pretty": true,
    "resolveJsonModule": true,
    "sourceMap": true,
    "strict": true,
    "strictBindCallApply": false,
    "strictNullChecks": true
  },
  "include": [
    "./src/index.ts",
    "./src/index.spec.ts"
  ]
}